{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://pulsestream.example/event.schema.json",
  "title": "PulseStream normalized event",
  "description": "Contract for messages published to the `events` Pub/Sub topic.",
  "type": "object",
  "required": ["event_id", "event_type", "wiki", "occurred_at"],
  "properties": {
    "event_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "minLength": 1 },
    "wiki": { "type": "string", "minLength": 1 },
    "title": { "type": ["string", "null"] },
    "user": { "type": ["string", "null"] },
    "occurred_at": {
      "type": "string",
      "description": "ISO-8601 UTC timestamp of when the event occurred."
    },
    "bot": { "type": "boolean" }
  },
  "additionalProperties": true
}
